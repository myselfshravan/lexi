# Copy to .env and fill in.  (run.sh loads .env automatically)
GROQ_API_KEY=gsk_your_key_from_console_groq_com
ALEXA_SKILL_ID=amzn1.ask.skill.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GROQ_MODEL=openai/gpt-oss-120b
# Home automation hub (leave empty for safe dry-run). Point at your Schneider/Wiser
# hub, KNX-IP gateway, or Home Assistant REST endpoint.
HOME_HUB_URL=
HOME_HUB_TOKEN=
PORT=8080
LOG_LEVEL=INFO
